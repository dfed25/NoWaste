# Base app URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: port for npm run dev:mobile, npm run ios|android, sim:* (default 3000). MOBILE_PORT is an alias.
# MOBILE_DEV_PORT=3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role — server only. Required for POST /api/auth/sign-up/restaurant (admin createUser).
# SUPABASE_SERVICE_ROLE_KEY=

# Stripe — https://dashboard.stripe.com/apikeys (use matching test or live keys)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Webhooks — https://stripe.com/docs/webhooks#verify-events
STRIPE_WEBHOOK_SECRET=
# Tutorial / hosted checkout preview flow (src/app/checkout/preview) — Price id from Dashboard
STRIPE_CHECKOUT_PRICE_ID=
# Optional: email used when POST /api/checkout_sessions has no customer_email (Stripe sample button)
# STRIPE_CHECKOUT_DEMO_EMAIL=
# Optional: existing Stripe Customer id (cus_...) for returning-customer sessions (server-only)
# STRIPE_CHECKOUT_CUSTOMER_ID=
# Branding (logo, colors): https://dashboard.stripe.com/settings/branding
# Tax (required for automatic_tax in create-checkout-session): https://dashboard.stripe.com/settings/tax

# Server-side session signature secret (admin CSV auth, nw-session-sig, etc.)
AUTH_SESSION_SECRET=

# Optional: when set, POST /api/auth/sign-up/restaurant requires this exact enrollment code (server-validated).
# RESTAURANT_SIGNUP_CODE=

# Optional: when a restaurant_staff user has no restaurant_id in Supabase metadata, signed cookies
# still mint if this matches your seeded restaurant id (local dev).
# DEFAULT_STAFF_RESTAURANT_ID=

# Set to 1 to allow POST /api/auth/nw-session in production (dev allows by default)
ALLOW_NW_SESSION_ISSUE=

# Required in production: must match request header x-nw-session-issue-secret when minting NW session cookies
NW_SESSION_ISSUE_SECRET=

# Background job secret for reservation expiration endpoint
EXPIRE_RESERVATIONS_SECRET=
