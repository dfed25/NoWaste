{
  "name": "tmpnext",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev",
    "dev:mobile": "next dev --webpack --hostname 0.0.0.0 --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:unit": "vitest run src/lib",
    "test:component": "vitest run src/components",
    "test:integration": "vitest run src/app/api",
    "test:ci": "vitest run --reporter=dot",
    "mobile:ios:add": "npx cap add ios",
    "mobile:sync": "npm run build && npx cap sync ios",
    "mobile:ios:open": "npx cap open ios",
    "mobile:ios:run": "npx cap run ios -l --external"
  },
  "dependencies": {
    "@capacitor/core": "^7.6.1",
    "@capacitor/ios": "^7.6.1",
    "@hookform/resolvers": "^5.2.2",
    "@supabase/supabase-js": "^2.101.1",
    "clsx": "^2.1.1",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "stripe": "^21.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.6.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "jsdom": "^27.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
